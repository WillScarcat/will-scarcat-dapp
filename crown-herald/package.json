{
  "name": "crown-herald",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Watches BalladHook's CrownClaimed event on Robinhood Chain (4663) and announces new Bard's Crown holders to Telegram.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "generate:notes": "tsx scripts/generate-notes.ts",
    "test:mock": "tsx src/test-mock.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "viem": "^2.21.0",
    "grammy": "^1.30.0",
    "ffmpeg-static": "^5.2.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "@types/node": "^20.14.0"
  }
}
